{
  "step": 6,
  "title": "Pre-commit Framework",
  "installed_at": "2026-04-11T00:00:00Z",
  "pre_commit_version": "4.5.1",
  "configs": [
    {
      "file": ".pre-commit-config.yaml",
      "stack": "python",
      "layers": [0, 1, 2, 3, 4, 6],
      "hooks": [
        "config-validation",
        "trailing-whitespace",
        "end-of-file-fixer",
        "check-yaml",
        "check-json",
        "check-added-large-files",
        "check-merge-conflict",
        "no-commit-to-branch",
        "ruff",
        "ruff-format",
        "detect-secrets"
      ]
    },
    {
      "file": ".pre-commit-config-ts.yaml",
      "stack": "typescript",
      "layers": [0, 1, 3, 6],
      "hooks": [
        "config-validation-ts",
        "typescript-compile",
        "jest-tia",
        "npm-audit"
      ]
    }
  ],
  "ci_jobs": [
    "validate-pr-title",
    "validate-branch-name"
  ],
  "branch_protection_contexts": [
    "lint",
    "test",
    "integration",
    "validate-pr-title",
    "validate-branch-name"
  ],
  "scripts": [
    "scripts/install-precommit-hooks.sh",
    "scripts/validate-configs-py.sh",
    "scripts/validate-configs-ts.sh",
    "scripts/jest-tia.sh",
    "scripts/npm-audit-check.sh"
  ],
  "secrets_baseline": ".secrets.baseline",
  "all_hooks_passing": true
}
